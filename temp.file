
    def right_button_pressed_die(self):
        self.x_move = -2.5
        self.rpress = True
        self.rat = 1

    def right_button_pressed_grounded(self):
        self.x_move = -2.5
        self.rpress = True
        self.next_imgs.append((1, 1))
        self.rat = 1

    def right_button_pressed_air(self):
        self.x_move = -2.5
        self.rpress = True
        self.next_imgs.append((5, 1))
        self.rat = 1      